# SIA HMS — Environment Variables
# Copy to .env and fill in real values

# ─────────────────────────────
# Django
# ─────────────────────────────
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings.development
ALLOWED_HOSTS=localhost,127.0.0.1,.siaenterprises.com.np

# ─────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────
POSTGRES_DB=sia_hms_db
POSTGRES_USER=sia_hms_user
POSTGRES_PASSWORD=sia_hms_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ─────────────────────────────
# Redis
# ─────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# ─────────────────────────────
# MinIO (S3-compatible storage)
# ─────────────────────────────
MINIO_ROOT_USER=sia_minio_admin
MINIO_ROOT_PASSWORD=sia_minio_password_change_me
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET_NAME=sia-hms-media
AWS_ACCESS_KEY_ID=sia_minio_admin
AWS_SECRET_ACCESS_KEY=sia_minio_password_change_me
AWS_STORAGE_BUCKET_NAME=sia-hms-media
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_USE_SSL=False

# ─────────────────────────────
# JWT
# ─────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─────────────────────────────
# Email (SMTP)
# ─────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@siaenterprises.com.np
EMAIL_HOST_PASSWORD=your-email-app-password
DEFAULT_FROM_EMAIL=SIA HMS <noreply@siaenterprises.com.np>

# ─────────────────────────────
# Sparrow SMS (Nepal)
# ─────────────────────────────
SPARROW_SMS_TOKEN=your-sparrow-sms-token
SPARROW_SMS_FROM=SIA_HMS

# ─────────────────────────────
# eSewa Payment Gateway
# ─────────────────────────────
ESEWA_MERCHANT_CODE=EPAYTEST
ESEWA_SECRET_KEY=8gBm/:&EnhH.1/q
ESEWA_SANDBOX=True
ESEWA_GATEWAY_URL=https://rc-epay.esewa.com.np/api/epay/main/v2/form

# ─────────────────────────────
# Khalti Payment Gateway
# ─────────────────────────────
KHALTI_SECRET_KEY=test_secret_key_dc74e0fd45f245228696785480072936
KHALTI_SANDBOX=True
KHALTI_API_URL=https://a.khalti.com/api/v2

# ─────────────────────────────
# Fonepay
# ─────────────────────────────
FONEPAY_MERCHANT_CODE=FONEPAY_TEST
FONEPAY_SECRET_KEY=fonepay_secret_here
FONEPAY_SANDBOX=True

# ─────────────────────────────
# Frontend (Next.js)
# ─────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXTAUTH_SECRET=your-nextauth-secret-change-in-production
NEXTAUTH_URL=http://localhost:3000

# ─────────────────────────────
# Nginx / Domains
# ─────────────────────────────
DOMAIN=siaenterprises.com.np
