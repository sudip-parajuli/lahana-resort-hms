# SIA HMS — Frontend Environment Variables
# Copy to .env.local for local development

# Internal URL used by Next.js Route Handlers to call the Django backend
# In Docker this is the service name, locally it's localhost
INTERNAL_BACKEND_URL=http://127.0.0.1:8000

# Public-facing URL (used in client-side code)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Node environment
NODE_ENV=development
