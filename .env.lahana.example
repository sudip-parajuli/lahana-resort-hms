# ==============================================================================
# Lahana Resort PMS — Production Environment Configuration Template
# ==============================================================================
# Copy this file to .env on the production server (pms.lahanaresort.com)
# Replace all placeholder values with secure, real secrets.
# ==============================================================================

# ── 1. DEPLOYMENT MODE & SINGLE-TENANT OVERRIDES ──────────────────────────────
# Enables the single-tenant mode, bypassing SaaS multi-tenant schema routing
DEPLOYMENT_MODE=single_tenant
SINGLE_TENANT_SCHEMA=lahana_resort
IS_SAAS=False

# ── 2. DJANGO SETTINGS ────────────────────────────────────────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-to-a-secure-random-token-in-production

# Turn off debug mode in production to ensure safety and prevent info leaks
DJANGO_DEBUG=False

# Point to production settings file
DJANGO_SETTINGS_MODULE=config.settings.production

# Whitelist production domains and local subdomain aliases (no protocol/ports)
ALLOWED_HOSTS=pms.lahanaresort.com,www.pms.lahanaresort.com,lahana.localhost

# ── 3. DATABASE (POSTGRESQL) ──────────────────────────────────────────────────
# Database name, user, and credentials used by the PostgreSQL container
POSTGRES_DB=lahana_pms
POSTGRES_USER=lahana_user
POSTGRES_PASSWORD=use-a-strong-randomly-generated-password-here
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── 4. REDIS & CELERY TASK WORKERS ───────────────────────────────────────────
# Connection strings pointing to the running Redis container
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# ── 5. MINIO OBJECT STORAGE (S3 COMPATIBLE) ──────────────────────────────────
# Storage credentials for checking guest documents, room photos, and invoices
MINIO_ROOT_USER=lahana_minio_admin
MINIO_ROOT_PASSWORD=use-a-strong-minio-admin-password
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET_NAME=lahana-pms-media

# AWS compatibility config matching the MinIO credentials above
AWS_ACCESS_KEY_ID=lahana_minio_admin
AWS_SECRET_ACCESS_KEY=use-a-strong-minio-admin-password
AWS_STORAGE_BUCKET_NAME=lahana-pms-media
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_USE_SSL=False

# ── 6. JWT TOKENS SECURE CHANNELS ─────────────────────────────────────────────
# Token validity periods for staff user sessions
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── 7. EMAIL CONFIGURATION (SMTP) ─────────────────────────────────────────────
# Standard SMTP configuration for guest booking email confirmations
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
# Google App Password or regular SMTP password
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=Lahana Resort <info@lahanaresort.com>

# ── 8. SPARROW SMS GATEWAY (NEPAL) ────────────────────────────────────────────
# Token provided by Sparrow SMS (sparrowsms.com) for sending notification messages
SPARROW_SMS_TOKEN=your-registered-sparrow-sms-token
SPARROW_SMS_FROM=LahanaRes

# ── 9. NEPAL PAYMENT GATEWAYS (PRODUCTION CREDENTIALS) ───────────────────────
# eSewa Configs: Switch sandbox to False and populate live merchant key/code
ESEWA_MERCHANT_CODE=
ESEWA_SECRET_KEY=
ESEWA_SANDBOX=True
ESEWA_GATEWAY_URL=https://rc-epay.esewa.com.np/api/epay/main/v2/form

# Khalti Configs: Switch sandbox to False and populate live private secret key
KHALTI_SECRET_KEY=
KHALTI_SANDBOX=True
KHALTI_API_URL=https://a.khalti.com/api/v2

# Fonepay Configs: Switch sandbox to False and populate merchant details
FONEPAY_MERCHANT_CODE=
FONEPAY_SECRET_KEY=
FONEPAY_SANDBOX=True

# ── 10. FRONTEND (NEXT.JS) & DOMAIN SETUP ────────────────────────────────────
# Next.js API endpoints. Must point to the production domain protocol URL
NEXT_PUBLIC_API_URL=https://pms.lahanaresort.com
NEXT_PUBLIC_WS_URL=wss://pms.lahanaresort.com
NEXT_PUBLIC_DEPLOYMENT_MODE=single_tenant
NEXT_PUBLIC_PROPERTY_NAME=Lahana Resort

# NextAuth Configs
NEXTAUTH_SECRET=generate-a-long-random-string-for-nextauth
NEXTAUTH_URL=https://pms.lahanaresort.com

# Nginx host mapping
DOMAIN=lahanaresort.com
CORS_ALLOWED_ORIGINS=https://lahanaresort.com,https://www.lahanaresort.com
